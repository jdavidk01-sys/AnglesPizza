@model AngelesPizza.Models.Order

@{
    Layout = null;
}

<!DOCTYPE html>

<html>

<head>

    <meta charset="utf-8" />

    <title>Comanda @Model.OrderNumber</title>

    <style>

            h2, h4, p {
                margin: 0;
                text-align: center;
            }

            hr {
                border: none;
                border-top: 1px dashed #000;
                margin: 8px 0;
            }

            table {
                width: 100%;
                border-collapse: collapse;
            }

            .right {
                text-align: right;
            }

            .center {
                text-align: center;
            }

            .small {
                font-size: 11px;
            }

            @@media print {

                body {
                    width: auto;
                    margin: 0;
                    padding: 0;
                    box-shadow: none;
                }

                @@page {
                    size: 80mm auto;
                    margin: 3mm;
                }
            }

            body {
                width: 80mm;
                min-height: 100vh;
                margin: 20px auto;
                padding: 5mm;
                font-family: Arial, Helvetica, sans-serif;
                font-size: 12px;
                background: white;
                box-shadow: 0 0 10px rgba(0,0,0,.2);
            }

    </style>

</head>

<body>

    <h2>ÁNGELES PIZZA</h2>

    <h3>@ViewBag.Copy</h3>

    <hr />

    <p><strong>Pedido #@Model.OrderNumber</strong></p>

    <p>@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>

    <hr />

    @if (Model.RestaurantTable != null)
    {
        <div class="section">
            <strong>Mesa:</strong> @Model.RestaurantTable.Name
        </div>
    }

    @if (Model.Customer != null)
    {
        <div class="section">
            <strong>Cliente:</strong> @Model.Customer.Name
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Customer.Phone))
        {
            <div class="section">
                <strong>Tel:</strong> @Model.Customer.Phone
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.Customer.Address))
        {
            <div class="section">
                <strong>Dirección:</strong>

                <br />

                @Model.Customer.Address
            </div>
        }
    }

    <hr />

    @foreach (var item in Model.OrderDetails)
    {
        <div style="margin-bottom:12px;">

            <strong style="font-size:14px;">
                @item.Product.Name
            </strong>

            @foreach (var modifier in item.OrderDetailModifiers)
            {
                <div class="small">
                    + @modifier.ProductModifier.Name
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(item.Notes))
            {
                <div class="small">

                    <strong>** OBS: @item.Notes **</strong>

                </div>
            }

        </div>
    }

    <hr />

    <p>

        *** FIN DE COMANDA ***

    </p>

    <script>

            window.onload = function () {

                window.print();

                setTimeout(function () {

                    @if ((string)ViewBag.Copy == "COCINA")
                    {
                            <text>
                                window.location.href = "/Order/PrintKitchen/@Model.Id?copy=PIZZERO";
                            </text>
                    }
                    else
                    {
                            <text>
                                window.location.href = "/OrderDashboard";
                            </text>
                    }

                }, 800);

            };

    </script>

</body>

</html>