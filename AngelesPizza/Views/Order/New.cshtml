@{
    ViewData["Title"] = "Nuevo Pedido";
}

<div class="container-fluid">

    <h2 class="mb-4">
        Nuevo Pedido
    </h2>

    <div class="row">

        <!-- PANEL IZQUIERDO -->
        <div class="col-md-8">

            <div class="card shadow-sm mb-3">

                <div class="card-header">
                    <strong>Pedido</strong>
                </div>

                <div class="card-body">

                    <div class="mb-3">

                        <label class="form-label">Tipo de Pedido</label>

                        <select id="OrderType" name="OrderType" class="form-select" asp-items="ViewBag.OrderTypes">
                            <option value=""></option>
                        </select>

                    </div>

                    <div class="mb-3">

                        <label class="form-label">Mesa</label>

                        <select id="RestaurantTableId"
                                class="form-select"
                                asp-items="ViewBag.Tables">

                            <option value="">Selecciona</option>

                        </select>

                    </div>

                    <div class="card shadow-sm mb-3">

                        <div class="card-header py-2 text-muted small fw-bold">
                            Cliente
                        </div>

                        <div class="card-body p-3">

                            <div class="mb-3">
                                <label class="form-label small mb-1">Buscar Cliente</label>
                                <select id="CustomerId" class="form-select form-select-sm" asp-items="ViewBag.Customers">
                                    <option value="">Selecciona</option>
                                </select>
                            </div>

                            <!-- Fila de Nombre y Teléfono -->
                            <div class="row g-2 mb-3">
                                <div class="col">
                                    <label class="form-label small mb-1">Nombre</label>
                                    <input id="CustomerName" class="form-control form-control-sm">
                                </div>
                                <div class="col">
                                    <label class="form-label small mb-1">Teléfono</label>
                                    <input id="CustomerPhone" class="form-control form-control-sm">
                                </div>
                            </div>

                            <!-- Fila de Dirección y Referencia -->
                            <div class="row g-2 mb-3">
                                <div class="col">
                                    <label class="form-label small mb-1">Dirección</label>
                                    <textarea id="CustomerAddress" rows="2" class="form-control form-control-sm"></textarea>
                                </div>
                                <div class="col">
                                    <label class="form-label small mb-1">Referencia</label>
                                    <textarea id="CustomerReference" rows="2" class="form-control form-control-sm"></textarea>
                                </div>
                            </div>

                            <!-- Fila de Botones -->
                            <div class="row g-2">
                                <div class="col">
                                    <button id="btnUpdateCustomer" class="btn btn-sm btn-warning w-100">
                                        Guardar Cambios
                                    </button>
                                </div>
                                <div class="col">
                                    <button id="btnNewCustomer" class="btn btn-sm btn-danger w-100">
                                        Nuevo Cliente
                                    </button>
                                </div>
                            </div>

                        </div>
                    </div>

                    <hr />

                    <h5>Categorías</h5>

                    <div class="row g-2">

                        @foreach (var category in ViewBag.Categories)
                        {
                            <div class="col-md-4">

                                <button type="button" class="btn btn-outline-dark w-100 category-btn" data-id="@category.Id">
                                    @category.Name
                                </button>

                            </div>
                        }

                    </div>

                    <hr />

                    <h5>Productos</h5>

                    <div id="products" class="row g-2">
                    </div>

                </div>

            </div>

        </div>

        <!-- PANEL DERECHO -->
        <div class="col-md-4">

            <div class="card shadow-sm">

                <div class="card-header">
                    <strong>Pedido Actual</strong>
                </div>

                <div class="card-body">

                    <div id="orderDetails">

                        <div class="text-muted">
                            No hay productos agregados.
                        </div>

                    </div>

                    <hr />

                    <h5>

                        Total:
                        <span id="orderTotal">
                            $0
                        </span>

                    </h5>

                    <button id="btnConfirmOrder" class="btn btn-danger w-100">
                        Confirmar Pedido
                    </button>

                </div>

            </div>

        </div>

    </div>

</div>

<div class="modal fade" id="productModal" tabindex="-1">

    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title" id="productName">
                    Producto
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <input type="hidden" id="ProductId" />

                <div class="mb-3">

                    <label class="form-label">
                        Observaciones
                    </label>

                    <textarea id="Notes"
                              class="form-control"
                              rows="3"></textarea>

                </div>

                <hr />

                <h6>Modificadores</h6>

                <div id="modifierList">

                    <div class="text-muted">
                        Cargando...
                    </div>

                </div>

            </div>

            <div class="modal-footer">

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">

                    Cancelar

                </button>

                <button type="button"
                        id="btnAddProduct"
                        class="btn btn-danger">

                    Agregar

                </button>

            </div>

        </div>

    </div>

</div>



<div class="modal fade" id="customerModal" tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    Nuevo Cliente
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <div class="mb-3">

                    <label class="form-label">
                        Nombre
                    </label>

                    <input id="NewCustomerName"
                           class="form-control" />

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Teléfono
                    </label>

                    <input id="NewCustomerPhone"
                           class="form-control" />

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Dirección
                    </label>

                    <textarea id="NewCustomerAddress"
                              rows="2"
                              class="form-control"></textarea>

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Referencia
                    </label>

                    <textarea id="NewCustomerReference"
                              rows="2"
                              class="form-control"></textarea>

                </div>

            </div>

            <div class="modal-footer">

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">

                    Cancelar

                </button>

                <button type="button"
                        id="btnSaveCustomer"
                        class="btn btn-danger">

                    Guardar

                </button>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    <script>

        $(function () {

            $(".category-btn").click(function () {

                let categoryId = $(this).data("id");

                $.get("/Order/GetProducts", { categoryId: categoryId }, function (products) {

                    let html = "";

                    products.forEach(function (p) {

                        let image = p.hasImage
                            ? `/Product/GetImage/${p.id}`
                            : "/images/no-image.png";

                        html += `
                            <div class="col-md-3">

                                <button class="btn btn-outline-dark w-100 product-btn"
                                        data-id="${p.id}"
                                        data-name="${p.name}">

                                    <img src="${image}"
                                         class="img-fluid rounded mb-2"
                                         style="height:120px;object-fit:cover;" />

                                    <div><strong>${p.name}</strong></div>

                                    <small>$${p.price.toLocaleString()}</small>

                                </button>

                            </div>`;
                    });

                    $("#products").html(html);

                });

            });

        });

        $(document).on("click", ".product-btn", function () {

            $("#ProductId").val($(this).data("id"));

            $("#productName").text($(this).data("name"));

            $("#Notes").val("");

            $.get("/Order/GetModifiers", function (modifiers) {

                let html = "";

                modifiers.forEach(function (m) {

                    html += `
                        <div class="form-check">

                            <input class="form-check-input modifier-check"
                                   type="checkbox"
                                   value="${m.id}"
                                   data-cost="${m.extraCost}">

                            <label class="form-check-label">

                                ${m.name}
                                (+$${m.extraCost.toLocaleString()})

                            </label>

                        </div>`;
                });

                $("#modifierList").html(html);

                const modal = new bootstrap.Modal(document.getElementById("productModal"));
                modal.show();

            });

        });

        $("#btnAddProduct").click(function () {

            let modifierIds = [];

            $(".modifier-check:checked").each(function () {
                modifierIds.push($(this).val());
            });

            $.post("/Order/AddProduct", {

                productId: $("#ProductId").val(),
                notes: $("#Notes").val(),
                modifierIds: modifierIds

            }, function (response) {

                bootstrap.Modal.getInstance(
                    document.getElementById("productModal")
                ).hide();

                loadOrder();

            });

        });

        function loadOrder() {

            $.get("/Order/GetCurrentOrder", function (items) {

                let html = "";
                let total = 0;

                items.forEach(function (item, index) {

                    total += item.total;

                    html += `
                        <div class="card mb-2">

                            <div class="card-body p-2">

                                <div class="d-flex justify-content-between">

                                    <strong>${item.productName}</strong>

                                    <button class="btn btn-sm btn-outline-danger remove-item"
                                            data-index="${index}">
                                        <i class="bi bi-trash"></i>
                                    </button>

                                </div>`;

                    if (item.modifierNames.length > 0) {

                        html += `<div class="mt-2">`;

                        item.modifierNames.forEach(function (m) {

                            html += `<div class="text-primary small">
                                        + ${m}
                                     </div>`;
                        });

                        html += `</div>`;
                    }

                    if (item.notes) {

                        html += `
                            <div class="text-muted small mt-2">
                                <strong>Obs:</strong> ${item.notes}
                            </div>`;
                    }

                    html += `

                                <div class="text-end mt-2">
                                    <strong>$${item.total.toLocaleString()}</strong>
                                </div>

                            </div>

                        </div>`;
                });

                if (items.length === 0) {

                    html = `
                        <div class="text-muted">
                            No hay productos agregados.
                        </div>`;
                }

                $("#orderDetails").html(html);

                $("#orderTotal").text("$" + total.toLocaleString());

            });

        }

        $(document).on("click", ".remove-item", function () {

            let index = $(this).data("index");

            $.post("/Order/RemoveProduct", {

                index: index

            }, function () {

                loadOrder();

            });

        });


$("#btnConfirmOrder").click(function () {

    let btn = $(this);

    btn.prop("disabled", true);

    $.post("/Order/Confirm", {

        orderType: $("#OrderType").val(),
        customerId: $("#CustomerId").val(),
        restaurantTableId: $("#RestaurantTableId").val()

    }, function (response) {

        if (response.ok) {

            window.location.href = "/Order/ReceivePayment/" + response.orderId;

        }
        else {

            btn.prop("disabled", false);

            alert(response.message);
        }

    });

});

        new TomSelect("#CustomerId", {
            create: false
        });

        $("#CustomerId").change(function () {

            let id = $(this).val();

            if (id == "")
                return;

            $.get("/Customer/GetCustomer", {

                id: id

            }, function (response) {

                if (!response.ok)
                    return;

                $("#CustomerName").val(response.customer.name);
                $("#CustomerPhone").val(response.customer.phone);
                $("#CustomerAddress").val(response.customer.address);
                $("#CustomerReference").val(response.customer.reference);

            });

        });

        $("#btnUpdateCustomer").click(function () {

            $.post("/Customer/Update", {

                Id: $("#CustomerId").val(),
                Name: $("#CustomerName").val(),
                Phone: $("#CustomerPhone").val(),
                Address: $("#CustomerAddress").val(),
                Reference: $("#CustomerReference").val()

            }, function (response) {

                if (!response.ok) {

                    alert("No fue posible actualizar el cliente.");
                    return;

                }

                alert("Cliente actualizado.");

            });

        });

                $("#btnNewCustomer").click(function () {

            $("#NewCustomerName").val("");
            $("#NewCustomerPhone").val("");
            $("#NewCustomerAddress").val("");
            $("#NewCustomerReference").val("");

            const modal = new bootstrap.Modal(document.getElementById("customerModal"));

            modal.show();

        });

        //Modal de Customer
        $("#btnSaveCustomer").click(function () {

            $.post("/Customer/Create", {

                Name: $("#NewCustomerName").val(),
                Phone: $("#NewCustomerPhone").val(),
                Address: $("#NewCustomerAddress").val(),
                Reference: $("#NewCustomerReference").val()

            }, function (response) {

                if (!response.ok) {

                    alert("No fue posible crear el cliente.");
                    return;

                }

                let select = document.getElementById("CustomerId");
                let tom = select.tomselect;

                tom.addOption({
                    value: response.id,
                    text: response.name
                });

                tom.setValue(response.id);

                $("#CustomerName").val($("#NewCustomerName").val());
                $("#CustomerPhone").val($("#NewCustomerPhone").val());
                $("#CustomerAddress").val($("#NewCustomerAddress").val());
                $("#CustomerReference").val($("#NewCustomerReference").val());

                bootstrap.Modal
                    .getInstance(document.getElementById("customerModal"))
                    .hide();

            });

        });

    </script>


}