@model IEnumerable<AngelesPizza.ViewModels.User.UserListViewModel>

@{
    ViewData["Title"] = "Usuarios";
}


<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>Usuarios</h2>

        <a asp-action="Create"
           class="btn btn-primary">

            <i class="bi bi-plus-circle"></i>

            Nuevo Usuario

        </a>

    </div>

    <hr />

    <div class="card shadow-sm">

        @Html.AntiForgeryToken()

        <div class="card-body">

            <table id="tblUsers"
                   class="table table-hover align-middle">

                <thead>

                    <tr>

                        <th>Nombre</th>

                        <th>Usuario</th>

                        <th>Rol</th>

                        <th>Estado</th>

                        <th class="text-center" width="180">
                            Acciones
                        </th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>

                                @item.FullName

                            </td>

                            <td>

                                @item.UserName

                            </td>

                            <td>

                                <span class="badge bg-primary">

                                    @item.Role

                                </span>

                            </td>

                            <td>

                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">

                                        Activo

                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">

                                        Inactivo

                                    </span>
                                }

                            </td>

                            <td class="text-center">

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-secondary">

                                    <i class="bi bi-pencil-square"></i>

                                </a>

                                <a asp-action="ChangePassword"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-warning">

                                    <i class="bi bi-key"></i>

                                </a>

                                <button class="btn btn-sm @(item.IsActive ? "btn-danger" : "btn-success") btnToggleStatus"
                                        data-id="@item.Id">

                                    @if (item.IsActive)
                                    {
                                        <i class="bi bi-person-x"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-person-check"></i>
                                    }

                                </button>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

@section Scripts
{

    <script>

        $(function() {

            $("#tblUsers").DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/2.0.8/i18n/es-ES.json'
                }
            });

        });

        $(document).on("click", ".btnToggleStatus", function() {

            if (!confirm("¿Desea cambiar el estado del usuario?"))
                return;

            $.ajax({

                url: "/User/ToggleStatus",

                type: "POST",

                data: {

                    id: $(this).data("id"),

                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()

                },

                success: function(response) {

                    if (response.ok) {

                        location.reload();

                    } else {

                        alert(response.message);

                    }

                }

            });

        });

    </script>


}