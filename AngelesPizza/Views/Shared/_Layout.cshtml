<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AngelesPizza</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.2/css/dataTables.bootstrap5.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/3.0.7/css/responsive.bootstrap5.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AngelesPizza.styles.css" asp-append-version="true" />

    <link href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">

</head>

<style>

    body {
    padding-top: 75px;
    }

</style>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3 fixed-top">
            <div class="container-fluid">

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-center">

                    <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">AngelesPizza</a>

                    <ul class="navbar-nav">

                        <li class="nav-item">

                            <a class="nav-link text-dark"
                               asp-controller="Home"
                               asp-action="Index">

                                <i class="bi bi-house-door"></i>
                                Inicio

                            </a>

                        </li>

                        <!-- PEDIDOS -->

                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle text-dark"
                               href="#"
                               data-bs-toggle="dropdown">

                                Pedidos

                            </a>

                            <ul class="dropdown-menu">

                                <li>

                                    <a class="dropdown-item"
                                       asp-controller="Order"
                                       asp-action="New">

                                        Nuevo Pedido

                                    </a>

                                </li>

                                <li>

                                    <a class="dropdown-item"
                                       asp-controller="OrderDashboard"
                                       asp-action="Index">

                                        Pedidos Activos

                                    </a>

                                </li>

                            </ul>

                        </li>

                        <!-- CONFIGURACIÓN -->

                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle text-dark"
                               href="#"
                               data-bs-toggle="dropdown">

                                Configuración

                            </a>

                            <ul class="dropdown-menu">

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Category"
                                       asp-action="Index">

                                        Categorías

                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Product"
                                       asp-action="Index">

                                        Productos

                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="ProductModifier"
                                       asp-action="Index">

                                        Modificadores

                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="RestaurantTable"
                                       asp-action="Index">

                                        Mesas

                                    </a>
                                </li>

                            </ul>

                        </li>

                        <!-- REPORTES -->

                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle text-dark"
                               href="#"
                               data-bs-toggle="dropdown">

                                Reportes

                            </a>

                            <ul class="dropdown-menu">

                                <li>

                                    <a class="dropdown-item disabled"
                                       href="#">

                                        Ventas

                                    </a>

                                </li>

                                <li>

                                    <a class="dropdown-item disabled"
                                       href="#">

                                        Productos

                                    </a>

                                </li>

                            </ul>

                        </li>

                        <!-- USUARIOS -->

                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle text-dark"
                               href="#"
                               data-bs-toggle="dropdown">

                                Usuarios

                            </a>

                            <ul class="dropdown-menu">

                                <li>

                                    <a class="dropdown-item disabled"
                                       href="#">

                                        Usuarios

                                    </a>

                                </li>

                                <li>

                                    <a class="dropdown-item disabled"
                                       href="#">

                                        Roles

                                    </a>

                                </li>

                                <li>

                                    <a class="dropdown-item disabled"
                                       href="#">

                                        Recuperar Contraseña

                                    </a>

                                </li>

                            </ul>

                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - AngelesPizza - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.3.2/js/dataTables.js"></script>
    <script src="https://cdn.datatables.net/2.3.2/js/dataTables.bootstrap5.js"></script>
    <script src="https://cdn.datatables.net/responsive/3.0.7/js/dataTables.responsive.js"></script>
    <script src="https://cdn.datatables.net/responsive/3.0.7/js/responsive.bootstrap5.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
