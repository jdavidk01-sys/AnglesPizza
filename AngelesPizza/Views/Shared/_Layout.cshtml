<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AngelesPizza</title>
    <script>
            (function() {
                const theme = localStorage.getItem('theme') || 'light';
                document.documentElement.setAttribute('data-bs-theme', theme);
            })();
    </script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.2/css/dataTables.bootstrap5.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/3.0.7/css/responsive.bootstrap5.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AngelesPizza.styles.css" asp-append-version="true" />

    <link href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">

</head>

<style>

    body {
    padding-top: 75px;
    }

    #themeToggle:focus,
    #themeToggle:focus-visible {
        outline: none !important;
        box-shadow: none !important;
    }

</style>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm bg-body-tertiary border-bottom box-shadow mb-3 fixed-top">
            <div class="container-fluid">

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-center">

                    <img src="~/images/logo.png"
                         asp-append-version="true"
                         style="height:40px;"
                         class="me-2" />

                    <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">AngelesPizza</a>

                    <ul class="navbar-nav">

                        <li class="nav-item">

                            <a class="nav-link text-body"
                               asp-controller="Home"
                               asp-action="Index">

                                <i class="bi bi-house-door"></i>
                                Inicio

                            </a>

                        </li>

                        <!-- PEDIDOS -->

                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle text-body"
                               href="#"
                               data-bs-toggle="dropdown">

                                Pedidos

                            </a>

                            <ul class="dropdown-menu">

                                <li>

                                    <a class="dropdown-item"
                                       asp-controller="Order"
                                       asp-action="New">

                                        Nuevo Pedido

                                    </a>

                                </li>

                                <li>

                                    <a class="dropdown-item"
                                       asp-controller="OrderDashboard"
                                       asp-action="Index">

                                        Pedidos Activos

                                    </a>

                                </li>

                            </ul>

                        </li>

                        <!-- CONFIGURACIÓN -->

                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle text-body"
                               href="#"
                               data-bs-toggle="dropdown">

                                Configuración

                            </a>

                            <ul class="dropdown-menu">

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Category"
                                       asp-action="Index">

                                        Categorías

                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Product"
                                       asp-action="Index">

                                        Productos

                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="ProductModifier"
                                       asp-action="Index">

                                        Adicionales

                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="RestaurantTable"
                                       asp-action="Index">

                                        Mesas

                                    </a>
                                </li>

                            </ul>

                        </li>

                        <!-- REPORTES -->

                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle text-body"
                               href="#"
                               data-bs-toggle="dropdown">

                                Reportes

                            </a>

                            <ul class="dropdown-menu">

                                <li>

                                    <a class="dropdown-item disabled"
                                       href="#">

                                        Ventas

                                    </a>

                                </li>

                                <li>

                                    <a class="dropdown-item disabled"
                                       href="#">

                                        Productos

                                    </a>

                                </li>

                            </ul>

                        </li>

                        <!-- USUARIOS -->
                        @if (User.IsInRole("Administrador"))
                        {
                            <li class="nav-item dropdown">

                                <a class="nav-link dropdown-toggle text-body"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">

                                    Usuarios

                                </a>

                                <ul class="dropdown-menu">

                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="User"
                                           asp-action="Index">

                                            <i class="bi bi-people me-2"></i>

                                            Usuarios

                                        </a>

                                    </li>

                                </ul>

                            </li>
                        }

                    </ul>

                    <div class="d-flex align-items-center gap-3">

                        <div class="vr align-self-stretch my-2"></div>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="text-body">

                                <i class="bi bi-person-fill"></i>

                                @User.Identity.Name

                            </span>

                            <form asp-controller="Account"
                                  asp-action="Logout"
                                  method="post"
                                  class="m-0">

                                @Html.AntiForgeryToken()

                                <button type="submit"
                                        class="btn btn-link text-decoration-none p-0">

                                    <i class="bi bi-box-arrow-right"></i>

                                    Salir

                                </button>

                            </form>
                        }

                        <div class="vr align-self-stretch my-2"></div>

                        <button id="themeToggle"
                                class="btn p-0 border-0 bg-transparent">

                            <i id="themeIcon"
                               class="bi bi-moon-stars fs-5"></i>

                        </button>

                    </div>

                </div>

            </div>

        </nav>

    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - AngelesPizza - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.3.2/js/dataTables.js"></script>
    <script src="https://cdn.datatables.net/2.3.2/js/dataTables.bootstrap5.js"></script>
    <script src="https://cdn.datatables.net/responsive/3.0.7/js/dataTables.responsive.js"></script>
    <script src="https://cdn.datatables.net/responsive/3.0.7/js/responsive.bootstrap5.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>

    <script>
            document.addEventListener('DOMContentLoaded', () => {

                const html = document.documentElement;
                const btn = document.getElementById('themeToggle');

                updateButton(html.getAttribute('data-bs-theme') || 'light');

                btn.addEventListener('click', () => {

                    const newTheme =
                        html.getAttribute('data-bs-theme') === 'dark'
                            ? 'light'
                            : 'dark';

                    html.setAttribute('data-bs-theme', newTheme);
                    localStorage.setItem('theme', newTheme);

                    updateButton(newTheme);
                    btn.blur();
                });

                function updateButton(theme) {
                    document.getElementById('themeIcon').className =
                        theme === 'dark'
                            ? 'bi bi-sun fs-5'
                            : 'bi bi-moon-stars fs-5';
                }
            });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
