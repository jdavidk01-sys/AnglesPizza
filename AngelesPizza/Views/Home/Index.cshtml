@{
    ViewData["Title"] = "Inicio";
}

<div class="container">

    <div class="text-center mb-5">

        <h2 class="fw-bold">
            Ángeles Pizza
        </h2>

        <p class="text-muted">
            Sistema de Punto de Venta
        </p>

    </div>

    <div class="row g-4">

        <!-- Nuevo Pedido -->
        <div class="col-md-6">

            <div class="card shadow-sm h-100">

                <div class="card-body text-center">

                    <i class="bi bi-plus-circle fs-1 text-danger"></i>

                    <h4 class="mt-3">
                        Nuevo Pedido
                    </h4>

                    <p class="text-muted">
                        Crear un nuevo pedido para mesa, domicilio o para llevar.
                    </p>

                    <a asp-controller="Order"
                       asp-action="New"
                       class="btn btn-danger w-50">

                        Ir al módulo

                    </a>

                </div>

            </div>

        </div>

        <!-- Pedidos Activos -->
        <div class="col-md-6">

            <div class="card shadow-sm h-100">

                <div class="card-body text-center">

                    <i class="bi bi-receipt fs-1 text-warning"></i>

                    <h4 class="mt-3">
                        Pedidos Activos
                    </h4>

                    <p class="text-muted">
                        Consultar, editar y administrar los pedidos en proceso.
                    </p>

                    <a asp-controller="OrderDashboard"
                       asp-action="Index"
                       class="btn btn-warning text-white w-50">

                        Ver pedidos

                    </a>

                </div>

            </div>

        </div>

        <!-- Configuración -->
        <div class="col-md-6">

            <div class="card shadow-sm h-100">

                <div class="card-body text-center">

                    <i class="bi bi-gear fs-1 text-secondary"></i>

                    <h4 class="mt-3">
                        Configuración
                    </h4>

                    <p class="text-muted">
                        Administrar productos, categorías, modificadores, clientes y mesas.
                    </p>

                    <a asp-controller="Category"
                       asp-action="Index"
                       class="btn btn-secondary w-50">

                        Administrar

                    </a>

                </div>

            </div>

        </div>

        <!-- Reportes -->
        <div class="col-md-6">

            <div class="card shadow-sm h-100">

                <div class="card-body text-center">

                    <i class="bi bi-bar-chart fs-1 text-success"></i>

                    <h4 class="mt-3">
                        Reportes
                    </h4>

                    <p class="text-muted">
                        Consultar ventas, productos y estadísticas del negocio.
                    </p>

                    <button class="btn btn-success w-50" disabled>

                        Próximamente

                    </button>

                </div>

            </div>

        </div>

    </div>

    <hr class="my-5" />

    <div class="text-center text-muted">

        <strong>Ángeles Pizza POS</strong>

        <br />

        <small>Versión 1.0</small>

    </div>

</div>