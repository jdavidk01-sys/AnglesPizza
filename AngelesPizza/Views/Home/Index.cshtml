@{
    ViewData["Title"] = "Inicio";
}

<div class="container">

    <div class="text-center mb-5">

        <h2 class="fw-bold">
            Ángeles Pizza
        </h2>

        <p class="text-muted">
            Sistema de Punto de Venta
        </p>

        <img src="~/images/logo.png"
             asp-append-version="true"
             style="height:150px;"
             class="me-2" />

    </div>

    <div class="row g-4">

        <!-- Nuevo Pedido -->
        <div class="col-md-6">

            <div class="card shadow-sm h-100">

                <div class="card-body text-center">

                    <i class="bi bi-plus-circle fs-1 text-danger"></i>

                    <h4 class="mt-3">
                        Nuevo Pedido
                    </h4>

                    <p class="text-muted">
                        Crear un nuevo pedido para mesa, domicilio o para llevar.
                    </p>

                    <a asp-controller="Order"
                       asp-action="New"
                       class="btn btn-danger w-50">

                        Nuevo

                    </a>

                </div>

            </div>

        </div>

        <!-- Pedidos Activos -->
        <div class="col-md-6">

            <div class="card shadow-sm h-100">

                <div class="card-body text-center">

                    <i class="bi bi-receipt fs-1 text-success"></i>

                    <h4 class="mt-3">
                        Pedidos Activos
                    </h4>

                    <p class="text-muted">
                        Consultar, editar y administrar los pedidos en proceso.
                    </p>

                    <a asp-controller="OrderDashboard"
                       asp-action="Index"
                       class="btn btn-success w-50">

                        Ver pedidos

                    </a>

                </div>

            </div>

        </div>

    </div>

    <hr class="my-5" />

    <div class="text-center text-muted">

        <strong>Ángeles Pizza POS</strong>

        <br />

        <small>Versión 1.0</small>

    </div>

</div>