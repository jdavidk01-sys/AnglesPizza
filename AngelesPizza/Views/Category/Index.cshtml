@model IEnumerable<AngelesPizza.Models.Category>?

@{
    ViewData["Title"] = "Categorías";
}

<div class="container-fluid">

    <h2 class="mb-4">
        Categorías
    </h2>

    <div class="card shadow-sm mb-4">

        <div class="card-header">
            <strong>Búsqueda</strong>
        </div>

        <div class="card-body">

            <form asp-action="Index" method="get">

                <div class="row g-3 align-items-end">

                    <div class="col-md-6">

                        <label class="form-label">
                            Nombre o descripción
                        </label>

                        <input type="text"
                               class="form-control"
                               name="search"
                               value="@Context.Request.Query["search"]"
                               placeholder="Ingrese un criterio de búsqueda..." />

                    </div>

                    <div class="col-md-6 text-md-end">

                        <button type="submit"
                                class="btn btn-danger">
                            <i class="bi bi-search"></i>
                            Buscar
                        </button>

                        <button type="submit"
                                name="showAll"
                                value="true"
                                class="btn btn-warning">
                            <i class="bi bi-list"></i>
                            Ver Todas
                        </button>

                        <a asp-action="Create"
                           class="btn btn-success">
                            <i class="bi bi-plus-circle"></i>
                            Nueva Categoría
                        </a>

                    </div>

                </div>

            </form>

        </div>

    </div>


    @if (Model == null)
    {
        <div class="alert alert-warning">

            <i class="bi bi-info-circle"></i>

            Realice una búsqueda o presione
            <strong>Ver Todas</strong>
            para consultar las categorías.

        </div>
    }
    else if (!Model.Any())
    {
        <div class="alert alert-warning">

            <i class="bi bi-exclamation-circle"></i>

            No se encontraron categorías con los criterios indicados.

        </div>
    }
    else
    {
        <div class="card shadow-sm">

            <div class="card-header">
                <strong>Resultados</strong>
            </div>

            <div class="card-body">

                <table id="tblCategories"
                       class="table table-striped table-bordered">

                    <thead class="table-light">

                        <tr>

                            <th>Nombre</th>

                            <th>Descripción</th>

                            <th class="text-center">
                                Estado
                            </th>

                            <th class="text-center">
                                Acciones
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    @item.Name
                                </td>

                                <td>
                                    @item.Description
                                </td>

                                <td class="text-center">

                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-warning">
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            Inactivo
                                        </span>
                                    }

                                </td>

                                <td class="text-center">

                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-secondary btn-sm">

                                        <i class="bi bi-pencil-square"></i>
                                        Editar

                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>
    }

</div>

@section Scripts {

    <script>

        $(document).ready(function () {

            $('#tblCategories').DataTable({

                responsive: true,
                paging: true,
                ordering: true,
                searching: true,
                info: true,
                lengthChange: true,
                pageLength: 10,
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.8/i18n/es-ES.json'
                }

            });

        });

    </script>

}