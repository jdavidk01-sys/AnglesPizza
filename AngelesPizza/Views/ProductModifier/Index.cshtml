@model IEnumerable<AngelesPizza.Models.ProductModifier>?

@{
    ViewData["Title"] = "Modificadores";
}

<div class="card shadow-sm">

    <div class="card-header d-flex justify-content-between align-items-center">
        <h4 class="mb-0">
            <i class="bi bi-sliders"></i>
            Modificadores
        </h4>
    </div>

    <div class="card-body">

        <form asp-action="Index" method="get" class="row g-3 mb-4">

            <div class="col-md-8">
                <input type="text"
                       name="search"
                       value="@Context.Request.Query["search"]"
                       class="form-control"
                       placeholder="Buscar modificador o producto..." />
            </div>

            <div class="col-md-4 d-flex gap-2">

                <button type="submit"
                        class="btn btn-primary">
                    <i class="bi bi-search"></i>
                    Buscar
                </button>

                <a asp-action="Index"
                   asp-route-showAll="true"
                   class="btn btn-secondary">
                    <i class="bi bi-list"></i>
                    Ver Todas
                </a>

                <a asp-action="Create"
                   class="btn btn-success">
                    <i class="bi bi-plus-circle"></i>
                    Nuevo
                </a>

            </div>

        </form>

        @if (Model == null)
        {
            <div class="alert alert-info">
                <i class="bi bi-search"></i>
                Realice una búsqueda para visualizar los registros.
            </div>
        }
        else if (!Model.Any())
        {
            <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle"></i>
                No se encontraron registros.
            </div>
        }
        else
        {
            <table id="tabla"
                   class="table table-bordered table-hover align-middle">

                <thead class="table-light">
                    <tr>
                        <th>Producto</th>
                        <th>Nombre</th>
                        <th>Costo Adicional</th>
                        <th>Activo</th>
                        <th style="width:120px;">Acciones</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@item.Product.Name</td>

                            <td>@item.Name</td>

                            <td>$ @item.ExtraCost.ToString("N0")</td>

                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">
                                        Sí
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        No
                                    </span>
                                }
                            </td>

                            <td>

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-warning btn-sm">

                                    <i class="bi bi-pencil-square"></i>

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>
        }

    </div>

</div>

@section Scripts {

    <script>

        $(document).ready(function () {

            $('#tabla').DataTable({

                responsive: true,
                paging: true,
                ordering: true,
                searching: true,
                info: true,
                lengthChange: true,
                pageLength: 10,
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json'
                }

            });

        });

    </script>

}