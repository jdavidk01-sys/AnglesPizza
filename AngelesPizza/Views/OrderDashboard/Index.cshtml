@model IEnumerable<AngelesPizza.Models.Order>

@{
    ViewData["Title"] = "Pedidos Activos";
}

@{
    Func<AngelesPizza.Enums.OrderStatus, string> getStatusClass = ViewBag.StatusClass;
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>Pedidos Activos</h2>

        <div class="d-flex ms-auto align-items-center gap-2">
            <span class="badge bg-primary fs-6">
                @Model.Count() Pedidos
            </span>

        
            <a asp-controller="Order"
               asp-action="New"
               class="btn btn-danger">

                Nuevo Pedido

            </a>
        </div>

    </div>

    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-success">

            <i class="bi bi-check-circle"></i>

            No existen pedidos activos.

        </div>
    }
    else
    {
        <div class="row">

            @foreach (var order in Model)
            {
                <div class="col-lg-4 mb-4">

                    <div class="card shadow-sm h-100">

                        <div class="card-header">

                            <div class="d-flex justify-content-between align-items-center">

                                <strong>
                                    Pedido #@order.OrderNumber
                                </strong>

                                <span class="badge @getStatusClass(order.Status) fs-6">
                                    @order.Status
                                </span>

                            </div>

                            <small class="text-muted">

                                @order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")

                                <br />

                                <strong class="order-time"
                                      data-created="@DateTime.SpecifyKind(order.CreatedAt, DateTimeKind.Utc).ToString("yyyy-MM-ddTHH:mm:ssZ")">
                                </strong>

                            </small>

                        </div>

                        <div class="card-body">

                            @if (order.Customer != null)
                            {
                                <div>
                                    <strong>Cliente:</strong> @order.Customer.Name
                                </div>
                            }

                            <div>
                                <strong>Tipo pedido:</strong> @order.OrderType
                            </div>

                            @if (order.RestaurantTable != null)
                            {
                                <div>
                                    <strong>Mesa:</strong> @order.RestaurantTable.Name
                                </div>
                            }

                            <hr />

                            @foreach (var item in order.OrderDetails)
                            {
                                <div class="mb-2">

                                    <strong>
                                        @item.Product.Name
                                    </strong>

                                    @foreach (var modifier in item.OrderDetailModifiers)
                                    {
                                        <div class="ms-3">
                                            + @modifier.ProductModifier.Name
                                        </div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(item.Notes))
                                    {
                                        <div class="ms-3 text-danger">
                                            Obs: @item.Notes
                                        </div>
                                    }

                                </div>
                            }

                        </div>

                        <div class="card-footer">

                            <div class="d-flex gap-2">

                                <a asp-controller="OrderDashboard"
                                   asp-action="Edit"
                                   asp-route-id="@order.Id"
                                   class="btn btn-secondary w-50">

                                    <i class="bi bi-pencil-square"></i>

                                    Editar

                                </a>

                                @if (order.Status == AngelesPizza.Enums.OrderStatus.Creado)
                                {
                                    <button class="btn btn-outline-warning btnStatus w-50"
                                            data-id="@order.Id"
                                            data-status="Fila">

                                        Confirmar Pedido

                                    </button>
                                }

                                @if (order.Status == AngelesPizza.Enums.OrderStatus.Fila)
                                {
                                    <button class="btn btn-warning btnStatus w-50"
                                            data-id="@order.Id"
                                            data-status="Preparando">

                                        Preparar

                                    </button>
                                }

                                @if (order.Status == AngelesPizza.Enums.OrderStatus.Preparando)
                                {
                                    <button class="btn btn-success btnStatus w-50"
                                            data-id="@order.Id"
                                            data-status="Listo">

                                        Marcar como Listo

                                    </button>
                                }

                                @if (order.Status == AngelesPizza.Enums.OrderStatus.Listo)
                                {
                                    <button class="btn btn-primary btnStatus w-50"
                                            data-id="@order.Id"
                                            data-status="Entregado">

                                        Entregar

                                    </button>
                                }

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>

@section Scripts{

    <script>

        function updateOrderTimes() {

            $(".order-time").each(function () {


                const created = new Date(this.dataset.created);
                const now = new Date();


                const minutes = Math.floor((now - created) / 60000);

                if (minutes < 60) {

                    $(this).html("⏱ " + minutes + " min");

                }
                else {

                    const hours = Math.floor(minutes / 60);
                    const mins = minutes % 60;

                    $(this).html("⏱ " + hours + " h " + mins + " min");

                }

            });

        }

        updateOrderTimes();

        setInterval(updateOrderTimes, 1000);

        $(document).on("click", ".btnStatus", function () {

            $.post("/OrderDashboard/ChangeStatus", {

                id: $(this).data("id"),
                status: $(this).data("status")

            }, function (response) {

                if (response.ok) {

                    location.reload();

                }

            });

        });

    </script>

}